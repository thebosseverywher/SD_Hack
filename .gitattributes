# Normalize line endings: store LF in the repo, check out native on Windows.
* text=auto eol=lf

# Windows batch files must be CRLF.
*.bat   text eol=crlf

# Unix shell / gradlew must stay LF (run on Linux/macOS CI).
*.sh     text eol=lf
gradlew  text eol=lf

# Binary assets (never normalize).
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gguf binary
*.onnx binary
*.bin binary
*.tflite binary
*.jar binary
