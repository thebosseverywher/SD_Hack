#!/bin/sh

#
# Gradle start up script for POSIX generated by Gradle.
#
# Standard Gradle wrapper. Requires gradle/wrapper/gradle-wrapper.jar, which is NOT
# committed in this skeleton (binary). Generate it once with a local Gradle 8.7:
#     gradle wrapper --gradle-version 8.7
# or simply open the project in Android Studio, which restores the wrapper jar.
#

set -e

APP_HOME=$(cd "$(dirname "$0")" >/dev/null && pwd)
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

if [ -z "$JAVA_HOME" ]; then
    JAVACMD=java
else
    JAVACMD="$JAVA_HOME/bin/java"
fi

if [ ! -f "$CLASSPATH" ]; then
    echo "gradle-wrapper.jar is missing. Run 'gradle wrapper --gradle-version 8.7' or open in Android Studio." >&2
    exit 1
fi

exec "$JAVACMD" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
